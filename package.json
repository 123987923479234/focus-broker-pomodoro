{
  "name": "focus-broker",
  "private": true,
  "version": "0.1.0",
  "description": "Task-driven Pomodoro workspace for deep focus and daily review",
  "author": "Focus Broker Team",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "predev": "node scripts/patch-vite-windows.cjs",
    "prebuild": "node scripts/patch-vite-windows.cjs",
    "dev": "npm run web",
    "dev:source": "vite --config vite.config.js --configLoader native --host 127.0.0.1",
    "build": "tsc -b && vite build --config vite.config.js --configLoader native",
    "web": "npm run build && node scripts/serve-dist.cjs",
    "preview": "node scripts/serve-dist.cjs",
    "desktop:run": "npm run build && electron .",
    "desktop:portable": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-desktop-portable.ps1",
    "desktop:pack": "npm run build && electron-builder --dir --config electron-builder.yml",
    "desktop:dist": "npm run build && electron-builder --win portable nsis --config electron-builder.yml --publish never"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.5.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
